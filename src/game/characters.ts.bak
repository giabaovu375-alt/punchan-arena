export type CharacterId = "warrior" | "mage" | "rogue";

export interface CharacterDef {
  id: CharacterId;
  name: string;
  title: string;
  description: string;
  color: number; // hex for placeholder mesh tint
  accent: string; // tailwind/CSS color for UI accent
  stats: { hp: number; atk: number; spd: number; def: number };
  moveSpeed: number;
  jumpSpeed: number;
}

export const CHARACTERS: CharacterDef[] = [
  {
    id: "warrior",
    name: "Kaelen",
    title: "Chiến Binh Thép",
    description:
      "Bậc thầy cận chiến, chịu sát thương cực tốt. Chậm nhưng đáng sợ trong giao tranh.",
    color: 0xc24a2a,
    accent: "#ff7a45",
    stats: { hp: 95, atk: 80, spd: 45, def: 90 },
    moveSpeed: 4.2,
    jumpSpeed: 6.5,
  },
  {
    id: "mage",
    name: "Lyra",
    title: "Pháp Sư Hắc Diệu",
    description:
      "Điều khiển ma thuật cổ. Sát thương phép cao, máu mỏng, cần giữ khoảng cách.",
    color: 0x5b7cff,
    accent: "#7c9bff",
    stats: { hp: 55, atk: 95, spd: 60, def: 40 },
    moveSpeed: 4.8,
    jumpSpeed: 7,
  },
  {
    id: "rogue",
    name: "Vex",
    title: "Sát Thủ Bóng Đêm",
    description:
      "Nhanh nhẹn, tàng hình, chí mạng cao. Cân bằng giữa tấn công và né tránh.",
    color: 0x2dd4a8,
    accent: "#2dd4a8",
    stats: { hp: 70, atk: 75, spd: 95, def: 55 },
    moveSpeed: 6.2,
    jumpSpeed: 8,
  },
];

export const getCharacter = (id: CharacterId) =>
  CHARACTERS.find((c) => c.id === id)!;
