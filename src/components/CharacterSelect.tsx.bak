import { useState } from "react";
import { CHARACTERS, type CharacterDef } from "@/game/characters";

interface Props {
  onConfirm: (character: CharacterDef) => void;
}

export function CharacterSelect({ onConfirm }: Props) {
  const [hoverId, setHoverId] = useState<string | null>(null);
  const [selectedId, setSelectedId] = useState<string>(CHARACTERS[0].id);
  const active = CHARACTERS.find((c) => c.id === (hoverId ?? selectedId))!;

  return (
    <div className="relative flex h-screen w-screen overflow-hidden bg-[#070710] text-white">
      {/* Background layers */}
      <div className="pointer-events-none absolute inset-0">
        <div
          className="absolute inset-0 transition-[background] duration-700"
          style={{
            background: `radial-gradient(ellipse at 30% 40%, ${active.accent}30, transparent 55%), radial-gradient(ellipse at 70% 80%, ${active.accent}20, transparent 60%), #050510`,
          }}
        />
        {/* Grid */}
        <div
          className="absolute inset-0 opacity-[0.07]"
          style={{
            backgroundImage:
              "linear-gradient(rgba(255,255,255,.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.6) 1px, transparent 1px)",
            backgroundSize: "60px 60px",
            maskImage: "radial-gradient(ellipse at center, black 30%, transparent 75%)",
          }}
        />
        {/* Floating particles */}
        {Array.from({ length: 30 }).map((_, i) => (
          <span
            key={i}
            className="absolute rounded-full bg-white/40"
            style={{
              left: `${(i * 37) % 100}%`,
              top: `${(i * 53) % 100}%`,
              width: `${1 + (i % 3)}px`,
              height: `${1 + (i % 3)}px`,
              animation: `floaty ${6 + (i % 7)}s ease-in-out ${i * 0.2}s infinite alternate`,
              opacity: 0.3 + (i % 5) * 0.1,
            }}
          />
        ))}
      </div>

      {/* Header */}
      <div className="absolute left-0 right-0 top-0 z-10 flex items-center justify-between px-8 py-6">
        <div className="flex items-center gap-3">
          <div
            className="h-2 w-2 rounded-full"
            style={{ background: active.accent, boxShadow: `0 0 12px ${active.accent}` }}
          />
          <div className="text-[10px] uppercase tracking-[0.5em] text-white/50">
            Aetherborn // Chapter 0
          </div>
        </div>
        <div className="text-[10px] uppercase tracking-[0.5em] text-white/40">
          Chọn anh hùng của bạn
        </div>
      </div>

      {/* Main: left detail / right cards */}
      <div className="relative z-10 grid h-full w-full grid-cols-1 lg:grid-cols-[1.1fr_1fr]">
        {/* Detail panel */}
        <div className="flex flex-col justify-center px-8 pb-32 pt-24 lg:px-16">
          <div className="text-xs uppercase tracking-[0.4em] text-white/40">
            {active.title}
          </div>
          <h1
            className="mt-3 font-serif text-7xl font-bold tracking-tight transition-all duration-500 lg:text-8xl"
            style={{ textShadow: `0 0 40px ${active.accent}66` }}
          >
            {active.name}
          </h1>
          <p className="mt-6 max-w-md text-sm leading-relaxed text-white/70">
            {active.description}
          </p>

          <div className="mt-10 max-w-md space-y-3">
            {(["hp", "atk", "spd", "def"] as const).map((k) => (
              <StatBar
                key={k}
                label={statLabel(k)}
                value={active.stats[k]}
                color={active.accent}
              />
            ))}
          </div>

          <div className="mt-10 flex items-center gap-4">
            <button
              onClick={() => onConfirm(active)}
              className="group relative overflow-hidden border-2 px-8 py-3 text-xs uppercase tracking-[0.4em] transition-all hover:scale-[1.02]"
              style={{
                borderColor: active.accent,
                color: "white",
                backgroundColor: `${active.accent}22`,
                boxShadow: `0 0 24px ${active.accent}55`,
              }}
            >
              <span className="relative z-10">Bắt đầu hành trình</span>
              <span
                className="absolute inset-0 -translate-x-full transition-transform duration-500 group-hover:translate-x-0"
                style={{ background: `linear-gradient(90deg, transparent, ${active.accent}44, transparent)` }}
              />
            </button>
            <div className="text-[10px] uppercase tracking-[0.3em] text-white/30">
              Enter để xác nhận
            </div>
          </div>
        </div>

        {/* Cards */}
        <div className="flex items-center justify-center px-6 pb-12 pt-20 lg:px-12">
          <div className="grid w-full max-w-md grid-cols-1 gap-4 sm:max-w-none sm:grid-cols-3 lg:max-w-md lg:grid-cols-1">
            {CHARACTERS.map((c) => {
              const isActive = (hoverId ?? selectedId) === c.id;
              return (
                <button
                  key={c.id}
                  onMouseEnter={() => setHoverId(c.id)}
                  onMouseLeave={() => setHoverId(null)}
                  onClick={() => setSelectedId(c.id)}
                  onDoubleClick={() => onConfirm(c)}
                  className={`group relative overflow-hidden border text-left transition-all duration-300 ${
                    isActive
                      ? "scale-[1.02] border-white/40"
                      : "border-white/10 hover:border-white/25"
                  }`}
                  style={{
                    background: isActive
                      ? `linear-gradient(135deg, ${c.accent}33, transparent 60%), rgba(255,255,255,0.02)`
                      : "rgba(255,255,255,0.02)",
                    boxShadow: isActive ? `0 0 30px ${c.accent}55` : "none",
                  }}
                >
                  {/* Portrait visual (procedural) */}
                  <div
                    className="relative h-40 overflow-hidden"
                    style={{
                      background: `radial-gradient(circle at 50% 60%, ${c.accent}66, transparent 70%), linear-gradient(180deg, #0a0a18, #050510)`,
                    }}
                  >
                    {/* Silhouette */}
                    <div className="absolute inset-x-0 bottom-0 flex justify-center">
                      <div
                        className="h-32 w-20 rounded-t-[40%]"
                        style={{
                          background: `linear-gradient(180deg, ${c.accent}, ${c.accent}00)`,
                          filter: "blur(2px)",
                        }}
                      />
                    </div>
                    <div
                      className="absolute left-1/2 top-6 h-8 w-8 -translate-x-1/2 rounded-full"
                      style={{ background: `${c.accent}`, boxShadow: `0 0 30px ${c.accent}` }}
                    />
                    {/* Rune */}
                    <div className="absolute right-3 top-3 text-[9px] uppercase tracking-widest text-white/40">
                      № {String(CHARACTERS.indexOf(c) + 1).padStart(2, "0")}
                    </div>
                  </div>

                  <div className="border-t border-white/10 p-4">
                    <div className="text-[10px] uppercase tracking-[0.3em] text-white/40">
                      {c.title}
                    </div>
                    <div className="mt-1 font-serif text-2xl font-bold">{c.name}</div>
                    <div className="mt-3 flex gap-1">
                      {(["hp", "atk", "spd", "def"] as const).map((k) => (
                        <div
                          key={k}
                          className="h-1 flex-1 rounded-full bg-white/10 overflow-hidden"
                        >
                          <div
                            className="h-full"
                            style={{ width: `${c.stats[k]}%`, background: c.accent }}
                          />
                        </div>
                      ))}
                    </div>
                  </div>
                </button>
              );
            })}
          </div>
        </div>
      </div>

      {/* Footer */}
      <div className="absolute bottom-0 left-0 right-0 z-10 flex items-center justify-between border-t border-white/5 bg-black/40 px-8 py-3 backdrop-blur">
        <div className="text-[10px] uppercase tracking-[0.4em] text-white/30">
          v0.1 · Framework Build
        </div>
        <div className="text-[10px] uppercase tracking-[0.4em] text-white/30">
          Double-click thẻ để bắt đầu nhanh
        </div>
      </div>

      <style>{`
        @keyframes floaty {
          from { transform: translateY(0px); }
          to   { transform: translateY(-30px); }
        }
      `}</style>
    </div>
  );
}

function StatBar({ label, value, color }: { label: string; value: number; color: string }) {
  return (
    <div>
      <div className="mb-1 flex items-center justify-between text-[10px] uppercase tracking-[0.3em] text-white/50">
        <span>{label}</span>
        <span style={{ color }}>{value}</span>
      </div>
      <div className="h-[3px] w-full overflow-hidden bg-white/10">
        <div
          className="h-full transition-all duration-500"
          style={{ width: `${value}%`, background: color, boxShadow: `0 0 8px ${color}` }}
        />
      </div>
    </div>
  );
}

function statLabel(k: "hp" | "atk" | "spd" | "def") {
  return k === "hp" ? "Sinh lực" : k === "atk" ? "Tấn công" : k === "spd" ? "Tốc độ" : "Phòng thủ";
}
